# ============================================
# AUTO-GIT PUBLISHER - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# API KEYS
# ============================================

# ── STEP 1: OpenRouter (FREE - 30+ free models, $0/run) ──────────────────
# Sign up:  https://openrouter.ai/
# Get key:  https://openrouter.ai/settings/keys  (click "Create Key")
# Free tier covers: Llama 3.3 70B, DeepSeek R1, Qwen3-Coder 480B, and more
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── STEP 2: Groq (FREE - fast inference) ────────────────────────────────
# Sign up:  https://console.groq.com/
# Get key:  https://console.groq.com/keys
# Used as:  Secondary fallback if OpenRouter rate-limited
GROQ_API_KEY=your_groq_api_key_here

# ── STEP 3: OpenAI (OPTIONAL - only needed if free models fail) ──────────
# Sign up:  https://platform.openai.com/
# Get key:  https://platform.openai.com/api-keys  (click "Create new secret key")
# Model:    gpt-5-nano @ $0.05/1M input tokens (400K context)
# NOTE:     With OpenRouter free models, you may never need this
OPENAI_API_KEY=sk-your-openai-key-here

# ── GitHub (Required for publishing repos) ───────────────────────────────
# Get token: https://github.com/settings/tokens/new
# Required scopes: repo, workflow, write:packages
GITHUB_TOKEN=your_github_token_here

# GitHub Username (for repo creation)
GITHUB_USERNAME=your_github_username

# ============================================
# MODEL CONFIGURATION
# ============================================

# Primary model for code generation
PRIMARY_CODE_MODEL=openai/gpt-oss-120b

# Secondary model for analysis tasks
ANALYSIS_MODEL=openai/gpt-oss-20b

# Local fallback models (Ollama)
LOCAL_CODE_MODEL=deepseek-coder-v2:16b
LOCAL_ANALYSIS_MODEL=deepcoder:14b

# Embedding model for novelty detection
EMBEDDING_MODEL=all-minilm:latest

# ============================================
# RATE LIMITING
# ============================================

# Groq rate limits (requests per minute)
GROQ_120B_RPM=30
GROQ_20B_RPM=30

# Max tokens per request
MAX_TOKENS_CODE_GEN=3000
MAX_TOKENS_ANALYSIS=1000

# Request retry settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2

# ============================================
# PIPELINE CONFIGURATION
# ============================================

# Novelty threshold (0-10, papers below this are skipped)
NOVELTY_THRESHOLD=7.0

# Priority threshold (0-1, papers below this are queued)
PRIORITY_THRESHOLD=0.5

# Max papers to process per run
MAX_PAPERS_PER_RUN=5

# Enable dry run (no actual GitHub publishing)
DRY_RUN=true

# Enable human review for high-complexity papers
HUMAN_REVIEW_ENABLED=true
COMPLEXITY_REVIEW_THRESHOLD=8.0

# ============================================
# ARXIV SEARCH QUERIES
# ============================================

# Comma-separated search queries
ARXIV_QUERIES=vision transformer,agentic AI systems,signal processing neural networks,diffusion models,reinforcement learning

# Max results per query
ARXIV_MAX_RESULTS=10

# Refresh interval (hours)
ARXIV_REFRESH_INTERVAL=24

# ============================================
# STORAGE & DATABASE
# ============================================

# Vector database type (chromadb or qdrant)
VECTOR_DB_TYPE=chromadb

# Database paths
DB_PATH=./data/pipeline.db
VECTOR_DB_PATH=./data/vector_db
CACHE_PATH=./data/cache

# ============================================
# LOGGING & MONITORING
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./logs

# Enable Discord notifications (optional)
DISCORD_WEBHOOK_ENABLED=false
DISCORD_WEBHOOK_URL=

# Enable Slack notifications (optional)
SLACK_WEBHOOK_ENABLED=false
SLACK_WEBHOOK_URL=

# ============================================
# REPOSITORY SETTINGS
# ============================================

# Default license for generated repos
DEFAULT_LICENSE=mit

# Default visibility
DEFAULT_REPO_VISIBILITY=public

# Add topics to repos
ADD_REPO_TOPICS=true
DEFAULT_TOPICS=ai,machine-learning,research,autonomous,paper-implementation

# Enable CI/CD workflows
ENABLE_GITHUB_ACTIONS=true

# ============================================
# COST CONTROLS
# ============================================

# Daily spending limit (USD)
DAILY_SPENDING_LIMIT=10.0

# Alert threshold (USD)
SPENDING_ALERT_THRESHOLD=8.0

# ============================================
# DEVELOPMENT
# ============================================

# Enable debug mode
DEBUG=false

# Mock external APIs (for testing)
MOCK_APIS=false

# Test paper arXiv ID (for single paper testing)
TEST_PAPER_ID=1706.03762
